# Copy to .env and fill in. .env is gitignored — never commit real keys.

# DEMO DEFAULT: the real self-hosted memory layer. Use "fake" for keyless
# dev (in-memory stub, no LLM, no Docker needed).
MEMORY_BACKEND=cognee        # cognee | fake

# Extra CORS origins for the API, comma-separated. localhost:3000 (CRA dev
# server) and localhost:5173 are always allowed; add deployed frontends here.
# ALLOWED_ORIGINS=https://dungeon-of-recall.example.com

# LLM — plain OpenAI defaults, nothing else.
LLM_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
COGNEE_SKIP_CONNECTION_TEST=true   # known preflight hang

# Cognee 1.2.2 defaults to auth=required + multi-tenant. We isolate by
# dataset-per-player instead — keep this off.
ENABLE_BACKEND_ACCESS_CONTROL=false

# Session memory: keep ON (the feedback loop needs QA entries). Profile
# queries carry a nonce to dodge stale session-cache answers; if staleness
# still appears, flip to false (see backend/memory/API_NOTES.md).
CACHING=true

# STORAGE — project-local, volume-mounted. Default would be inside
# site-packages and die on reinstall (see API_NOTES.md "storage trap").
COGNEE_DATA_ROOT=./data/cognee

# Relational store -> Postgres (docker compose up postgres).
# Graph (ladybug) + vector (lancedb) stay embedded under COGNEE_DATA_ROOT.
# No Docker? DB_PROVIDER=sqlite works for keyed solo dev (single process only).
DB_PROVIDER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=cognee
DB_PASSWORD=cognee
DB_NAME=cognee_db

# NOT self-hosted (track rules cover stores, not the LLM). Cognee Cloud is
# deliberately unused — self-hosted stack only:
# COGNEE_SERVICE_URL=https://<your-instance>.cognee.ai
# COGNEE_API_KEY=ck_...
