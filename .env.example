# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Team runs with the stub until Role A flips this to "cognee".
MEMORY_BACKEND=fake          # fake | cognee

LLM_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
COGNEE_SKIP_CONNECTION_TEST=true

# Cognee Cloud (claim the free Developer plan with code COGNEE-35):
# COGNEE_SERVICE_URL=https://<your-instance>.cognee.ai
# COGNEE_API_KEY=ck_...
